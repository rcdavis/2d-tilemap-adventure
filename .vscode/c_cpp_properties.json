{
	"version": 4,
	"configurations": [
		{
			"name": "Linux (Debug)",
			"includePath": [
				"${workspaceFolder}/Game/include/",
				"/usr/include"
			],
			"defines": [
				"DEBUG",
				"GLFW_INCLUDE_NONE",
				"LOGGING_ENABLED",
				"ASSERTS_ENABLED"
			],
			"compilerPath": "/usr/bin/gcc",
			"cStandard": "c17",
			"cppStandard": "c++17",
			"intelliSenseMode": "linux-gcc-x64"
		},
		{
			"name": "Linux (Release)",
			"includePath": [
				"${workspaceFolder}/Game/include/",
				"/usr/include"
			],
			"defines": [
				"NDEBUG",
				"GLFW_INCLUDE_NONE"
			],
			"compilerPath": "/usr/bin/gcc",
			"cStandard": "c17",
			"cppStandard": "c++17",
			"intelliSenseMode": "linux-gcc-x64"
		}
	]
}
